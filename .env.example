# ──────────────────────────────────────────────
# Coach"G" Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env.
# ──────────────────────────────────────────────

# ── Core ──
NODE_ENV=development
APP_NAME=CoachG
BACKEND_PORT=4000
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql://coachg:coachg@localhost:5432/coachg?schema=public
POSTGRES_USER=coachg
POSTGRES_PASSWORD=coachg
POSTGRES_DB=coachg

# ── Redis (cache + BullMQ) ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Auth (Keycloak self-hosted) ──
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=coachg
KEYCLOAK_CLIENT_ID=coachg-backend
KEYCLOAK_CLIENT_SECRET=changeme
# Local JWT fallback (used when Keycloak is disabled in dev)
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_PROVIDER=local  # local | keycloak

# ── Object Storage (ArvanCloud / S3-compatible; MinIO for local dev) ──
S3_ENDPOINT=http://localhost:9000
S3_REGION=ir-thr-at1
S3_BUCKET=coachg
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# ── AI (Anthropic Claude) ──
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=4096

# ── Security ──
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120
CORS_ORIGINS=http://localhost:3000
ENCRYPTION_KEY=32-byte-base64-key-change-me

# ── Observability ──
LOKI_URL=http://localhost:3100
PROMETHEUS_ENABLED=true
LOG_LEVEL=debug
