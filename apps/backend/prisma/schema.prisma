// Coach"G" — Prisma schema (authoritative domain model)
// See docs/DATABASE.md for the conceptual overview.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────
enum Role {
  ADMIN
  COACH
  CLIENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum GoalType {
  FAT_LOSS
  MUSCLE_GAIN
  RECOMP
  PERFORMANCE
  GENERAL_FITNESS
}

enum Sport {
  NONE
  FOOTBALL
  BASKETBALL
  VOLLEYBALL
  COMBAT
  RUNNING
}

enum PeriodizationModel {
  LINEAR
  BLOCK
  UNDULATING
}

enum ProgramPhase {
  ACCUMULATION
  INTENSIFICATION
  REALIZATION
  DELOAD
}

enum ProgramStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum MovementPattern {
  SQUAT
  HINGE
  LUNGE
  HORIZONTAL_PUSH
  VERTICAL_PUSH
  HORIZONTAL_PULL
  VERTICAL_PULL
  CARRY
  ROTATION
  GAIT
  PLYOMETRIC
  CONDITIONING
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum NutritionStrategy {
  FAT_LOSS
  MAINTENANCE
  MUSCLE_GAIN
  RECOMP
}

enum BloodMarkerType {
  FASTING_GLUCOSE
  HBA1C
  HDL
  LDL
  TRIGLYCERIDES
  VITAMIN_D
  TESTOSTERONE
  FERRITIN
}

enum MarkerFlag {
  LOW
  NORMAL
  HIGH
}

enum ReportStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

// ──────────────────────────────────────────────
// Identity & profiles
// ──────────────────────────────────────────────
model User {
  id            String         @id @default(cuid())
  email         String         @unique
  // Mirrors the Keycloak subject (OIDC). Null in pure local-dev mode.
  keycloakId    String?        @unique
  passwordHash  String? // local-dev fallback only
  role          Role           @default(COACH)
  firstName     String?
  lastName      String?
  isActive      Boolean        @default(true)
  coachProfile  CoachProfile?
  clientProfile ClientProfile? @relation("ClientUser")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
}

model CoachProfile {
  id          String          @id @default(cuid())
  user        User            @relation(fields: [userId], references: [id])
  userId      String          @unique
  businessName String?
  logoKey     String? // object-storage key for report branding
  specialties String[]
  bio         String?
  clients     ClientProfile[] @relation("CoachClients")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ClientProfile {
  id           String          @id @default(cuid())
  // The client's login identity (optional — coach can manage without a login).
  user         User?           @relation("ClientUser", fields: [userId], references: [id])
  userId       String?         @unique
  coach        CoachProfile    @relation("CoachClients", fields: [coachId], references: [id])
  coachId      String
  firstName    String
  lastName     String
  email        String?
  phone        String?
  dateOfBirth  DateTime?
  gender       Gender?
  assessments  Assessment[]
  goals        Goal[]
  programs     Program[]
  nutritionPlans NutritionPlan[]
  recoveryPlans  RecoveryPlan[]
  bloodwork    BloodworkPanel[]
  progress     ProgressEntry[]
  measurements Measurement[]
  documents    Document[]
  reports      Report[]
  messages     Message[]
  notes        CoachNote[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?

  @@index([coachId])
}

// ──────────────────────────────────────────────
// Assessment & goals
// ──────────────────────────────────────────────
model Assessment {
  id                  String          @id @default(cuid())
  client              ClientProfile   @relation(fields: [clientId], references: [id])
  clientId            String
  version             Int             @default(1)
  age                 Int
  gender              Gender
  heightCm            Float
  weightKg            Float
  bodyFatPct          Float?
  sport               Sport           @default(NONE)
  experience          ExperienceLevel
  injuries            String[]
  mobilityRestrictions String[]
  equipment           String[]
  trainingFrequency   Int // sessions/week
  scheduleAvailability Json? // e.g. {"mon":true,...}
  recoveryQuality     Int // 1-10
  sleepQuality        Int // 1-10
  stressLevel         Int // 1-10
  createdAt           DateTime        @default(now())

  @@index([clientId, version])
}

model Goal {
  id          String        @id @default(cuid())
  client      ClientProfile @relation(fields: [clientId], references: [id])
  clientId    String
  type        GoalType
  sport       Sport         @default(NONE)
  targetMetrics Json? // e.g. {"weightKg":80,"bodyFatPct":12}
  timeframeWeeks Int?
  programs    Program[]
  nutritionPlans NutritionPlan[]
  createdAt   DateTime      @default(now())

  @@index([clientId])
}

// ──────────────────────────────────────────────
// Exercise library (global, not coach-scoped)
// ──────────────────────────────────────────────
model Exercise {
  id                String             @id @default(cuid())
  slug              String             @unique
  name              String
  description       String
  videoUrl          String?
  equipment         String[]
  primaryMuscles    String[]
  secondaryMuscles  String[]
  movementPattern   MovementPattern
  difficulty        Difficulty
  contraindications String[]
  coachingCues      String[]
  sportTransferTags String[]
  programExercises  ProgramExercise[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([movementPattern])
  @@index([difficulty])
}

// ──────────────────────────────────────────────
// Program
// ──────────────────────────────────────────────
model Program {
  id            String             @id @default(cuid())
  client        ClientProfile      @relation(fields: [clientId], references: [id])
  clientId      String
  goal          Goal               @relation(fields: [goalId], references: [id])
  goalId        String
  name          String
  periodization PeriodizationModel
  durationWeeks Int
  daysPerWeek   Int
  status        ProgramStatus      @default(DRAFT)
  // AI explanation layer output (nullable; program is valid without it).
  aiRationale   String?
  weeks         ProgramWeek[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([clientId, status])
}

model ProgramWeek {
  id                String       @id @default(cuid())
  program           Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId         String
  weekIndex         Int
  phase             ProgramPhase
  volumeMultiplier  Float        @default(1.0)
  intensityMultiplier Float      @default(1.0)
  isDeload          Boolean      @default(false)
  days              ProgramDay[]

  @@index([programId])
}

model ProgramDay {
  id        String            @id @default(cuid())
  week      ProgramWeek       @relation(fields: [weekId], references: [id], onDelete: Cascade)
  weekId    String
  dayIndex  Int
  focus     String // e.g. "Lower / Speed"
  payload   Json? // warmup, conditioning, notes
  exercises ProgramExercise[]

  @@index([weekId])
}

model ProgramExercise {
  id            String     @id @default(cuid())
  day           ProgramDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  dayId         String
  exercise      Exercise   @relation(fields: [exerciseId], references: [id])
  exerciseId    String
  order         Int
  sets          Int
  reps          String // "8-10" or "5" or "30s"
  loadPctOf1RM  Float? // when % based
  rpe           Float? // when RPE based
  tempo         String?
  restSeconds   Int
  progressionRule String?

  @@index([dayId])
}

// ──────────────────────────────────────────────
// Nutrition
// ──────────────────────────────────────────────
model NutritionPlan {
  id           String            @id @default(cuid())
  client       ClientProfile     @relation(fields: [clientId], references: [id])
  clientId     String
  goal         Goal?             @relation(fields: [goalId], references: [id])
  goalId       String?
  strategy     NutritionStrategy
  bmr          Float
  tdee         Float
  goalCalories Float
  proteinG     Float
  carbsG       Float
  fatG         Float
  mealTiming   Json? // slots & timing strategy
  meals        Meal[]
  shoppingList String[]
  aiNotes      String?
  createdAt    DateTime          @default(now())

  @@index([clientId])
}

model Meal {
  id        String        @id @default(cuid())
  plan      NutritionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId    String
  name      String
  slot      String // breakfast/lunch/...
  calories  Float
  proteinG  Float
  carbsG    Float
  fatG      Float
  items     String[]

  @@index([planId])
}

// ──────────────────────────────────────────────
// Recovery
// ──────────────────────────────────────────────
model RecoveryPlan {
  id               String        @id @default(cuid())
  client           ClientProfile @relation(fields: [clientId], references: [id])
  clientId         String
  sleepTargetHours Float
  hydrationLiters  Float
  mobilityRoutine  String[]
  recoveryScore    Int // 0-100
  deloadRecommended Boolean      @default(false)
  recommendations  String[]
  aiNotes          String?
  createdAt        DateTime      @default(now())

  @@index([clientId])
}

// ──────────────────────────────────────────────
// Bloodwork (sensitive — field-encrypted at app layer)
// ──────────────────────────────────────────────
model BloodworkPanel {
  id        String         @id @default(cuid())
  client    ClientProfile  @relation(fields: [clientId], references: [id])
  clientId  String
  panelDate DateTime
  lab       String?
  notes     String?
  markers   BloodMarker[]
  createdAt DateTime       @default(now())

  @@index([clientId])
}

model BloodMarker {
  id             String          @id @default(cuid())
  panel          BloodworkPanel  @relation(fields: [panelId], references: [id], onDelete: Cascade)
  panelId        String
  type           BloodMarkerType
  // Sensitive PII: stored AES-256-GCM encrypted (app-level field encryption).
  // The numeric value is encrypted before persistence and decrypted on read.
  value          String
  unit           String
  referenceLow   Float?
  referenceHigh  Float?
  flag           MarkerFlag      @default(NORMAL)
  insight        String? // educational only — never diagnostic

  @@index([panelId])
}

// ──────────────────────────────────────────────
// Progress, files, messaging, notes
// ──────────────────────────────────────────────
model ProgressEntry {
  id            String        @id @default(cuid())
  client        ClientProfile @relation(fields: [clientId], references: [id])
  clientId      String
  entryDate     DateTime
  weightKg      Float?
  bodyFatPct    Float?
  waistCm       Float?
  strengthPRs   Json? // {"squat":140,...}
  sprintTimes   Json? // {"10m":1.8,...}
  jumpHeightCm  Float?
  compliancePct Float?
  recoveryScore Int?
  createdAt     DateTime      @default(now())

  @@index([clientId, entryDate])
}

model Measurement {
  id        String        @id @default(cuid())
  client    ClientProfile @relation(fields: [clientId], references: [id])
  clientId  String
  type      String // "photo" | "circumference" | ...
  objectKey String // object-storage key
  takenAt   DateTime
  createdAt DateTime      @default(now())

  @@index([clientId])
}

model Document {
  id        String        @id @default(cuid())
  client    ClientProfile @relation(fields: [clientId], references: [id])
  clientId  String
  name      String
  objectKey String
  mimeType  String
  sizeBytes Int
  createdAt DateTime      @default(now())

  @@index([clientId])
}

model Report {
  id        String        @id @default(cuid())
  client    ClientProfile @relation(fields: [clientId], references: [id])
  clientId  String
  status    ReportStatus  @default(PENDING)
  objectKey String? // PDF location once READY
  error     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([clientId])
}

model Message {
  id        String        @id @default(cuid())
  client    ClientProfile @relation(fields: [clientId], references: [id])
  clientId  String
  senderRole Role
  body      String
  readAt    DateTime?
  createdAt DateTime      @default(now())

  @@index([clientId, createdAt])
}

model CoachNote {
  id        String        @id @default(cuid())
  client    ClientProfile @relation(fields: [clientId], references: [id])
  clientId  String
  body      String
  createdAt DateTime      @default(now())

  @@index([clientId])
}

// ──────────────────────────────────────────────
// Audit (global)
// ──────────────────────────────────────────────
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String // e.g. "program.generate"
  entityType String
  entityId   String?
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
